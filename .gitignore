# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (commit only the example template)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# project tooling / local build artifacts
/node-compile-cache
/update-check
.deps-done
.deps-failed
.deps-install.log

# local inventory dumps that may contain secrets / machine info
/inventory/mcp-servers.json
/inventory/claude-desktop-config.json

# local pnpm store config (machine-specific path)
.npmrc

# automation/test artifacts
.playwright-mcp/
/*.png
members-test.csv
*.log

# stray package-manager temp artifacts
*.npm-*
.*-[0-9A-F][0-9A-F][0-9A-F][0-9A-F][0-9A-F][0-9A-F][0-9A-F][0-9A-F].*
